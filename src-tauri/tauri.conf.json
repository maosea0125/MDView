{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MDView",
  "version": "0.1.0",
  "identifier": "com.mdview.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "MDView",
        "width": 1000,
        "height": 700,
        "minWidth": 400,
        "minHeight": 300
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "mdown", "mkd", "mkdn", "mdwn", "mdtxt", "mdtext", "txt"],
        "mimeType": "text/markdown",
        "name": "Markdown Document",
        "role": "Viewer"
      }
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
